PORT=3001
# Metered.ca TURN credentials — required for WAN (internet) streaming.
# Sign up free at https://metered.ca, create a TURN server, copy the values below.
METERED_API_KEY=your_api_key_here
METERED_APP_NAME=your_app_name_here

# PostgreSQL connection string (Railway / Render / local)
DATABASE_URL=postgresql://user:password@localhost:5432/remotecamera

# Random secret for session signing — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_random_32_char_string

# Supabase Storage (cloud recording storage) — get from supabase.com → Project Settings → API
# Use the service_role key (not anon key) so the server can bypass RLS
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
